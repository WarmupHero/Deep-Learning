{
  "task_type": "regression",
  "input_dimension": 8,
  "loss": "mse",
  "preprocessing": {
  "enabled": true,
  "scale_features": true
  },
  "architectures": {
    "A1": [
      {"type": "dense", "units": 32, "activation": "sigmoid"},
      {"type": "dense", "units": 1, "activation": "linear"}
    ],
    "A2": [
      {"type": "dense", "units": 32, "activation": "relu"},
      {"type": "dense", "units": 32, "activation": "relu"},
      {"type": "dense", "units": 32, "activation": "relu"},
      {"type": "dense", "units": 1, "activation": "linear"}
    ]
  },
  "experiments": {
    "optimizers": ["sgd", "momentum", "adabelief"],
    "learning_rates": [0.1, 0.001],
    "batch_sizes": [16, 64],
    "epochs": 100,
    "early_stopping": true,
    "patience": 10,
    "min_delta": 0.0001
  }
}